// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl", "linux-musl-openssl-3.0.x"]
}

// NOTE: Currently configured for SQLite for local sandbox.
// When deploying to VPS with PostgreSQL, change provider to "postgresql"
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  username         String?   @unique
  passwordHash     String
  role             String    @default("USER") // "USER" or "ADMIN"
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?   // For Google Authenticator
  isBanned         Boolean   @default(false)
  lastKnownIp      String?   
  userAgent        String?   
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  resetToken       String?
  resetTokenExp    DateTime?

  firstName        String?
  lastName         String?
  fullName         String?
  phone            String?
  idNumber         String?
  companyRegNumber String?
  billingAddress   String?
  
  // Social Media Links
  socialFacebook   String?
  socialTwitter    String?
  socialInstagram  String?
  socialLinkedin   String?
  socialYoutube    String?
  socialTiktok     String?
  
  website          String?
  businessName     String?
  vatNumber        String?

  showProfileDetails Boolean @default(false)
  profileColor     String    @default("slate") // Color theme name or hex
  selectedTier     String    @default("FREE")  // "FREE" or "PREMIUM"
  tier             String    @default("FREE")  // "FREE" or "PREMIUM"

  listings         Listing[] 
  maxListings      Int       @default(1)
}

model VisitorLog {
  id             String    @id @default(uuid())
  ipAddress      String?
  userAgent      String?
  deviceType     String?
  path           String
  action         String?
  searchQuery    String?
  visitedAt      DateTime  @default(now())
}

model Listing {
  id             String    @id @default(uuid())
  userId         String    
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  status         String    @default("PENDING") // PENDING, APPROVED, REJECTED, EXPIRED

  // Business Details
  businessName   String
  category       String
  province       String
  city           String
  suburb         String
  description    String
  contactEmail   String
  contactPhone   String?
  websiteUrl     String?
  keywords       String?
  
  // Custom Social Presence Addons
  whatsappNumber String?
  facebookUrl    String?
  instagramUrl   String?
  tiktokUrl      String?
  youtubeUrl     String?
  
  publishedAt    DateTime?
  expiresAt      DateTime?

  // SEO Metrics (Migrated from local JSON)
  searchesLog    String?   // Store comma-separated or JSON list of historical search terms
  clicks         Int       @default(0)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  images         ListingImage[]
}

model ListingImage {
  id             String    @id @default(uuid())
  listingId      String
  listing        Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  
  imageData      Bytes     // Resized image blob
  mimeType       String    @default("image/jpeg")
  createdAt      DateTime  @default(now())
}
